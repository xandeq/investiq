# InvestIQ — Environment Variables Reference
# Copy to .env and fill in real values (NEVER commit .env with real secrets)
# All secrets at runtime are fetched from AWS Secrets Manager (tools/* prefix)

# --- Database ---
POSTGRES_PASSWORD=change-me-in-dev
DATABASE_URL=postgresql+asyncpg://postgres:change-me-in-dev@postgres:5432/investiq

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT (RSA keys — fetched from AWS SM tools/investiq-jwt at startup) ---
# In development you can generate a keypair:
#   openssl genrsa -out private_key.pem 2048
#   openssl rsa -in private_key.pem -pubout -out public_key.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# --- App ---
SECRET_KEY=change-me-in-production-use-secrets-manager
APP_URL=http://localhost:3100
ENVIRONMENT=development

# --- Email (Brevo — fetched from AWS SM tools/brevo at startup) ---
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@investiq.com.br
BREVO_FROM_NAME=InvestIQ

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8100
