# Backend environment variables
# Copy to .env — NEVER commit real secrets
# Production secrets are fetched from AWS Secrets Manager

# Database (PostgreSQL 16)
DATABASE_URL=postgresql+asyncpg://postgres:change-me@postgres:5432/investiq

# Redis
REDIS_URL=redis://redis:6379/0

# App
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
APP_URL=http://localhost:3100

# JWT — RSA keypair (fetch from AWS SM tools/investiq-jwt in production)
# Generate dev keys:
#   openssl genrsa -out private_key.pem 2048
#   openssl rsa -in private_key.pem -pubout -out public_key.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Email — Brevo (fetch from AWS SM tools/brevo in production)
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@investiq.com.br
BREVO_FROM_NAME=InvestIQ
