# InvestIQ Backend — variáveis de ambiente
# Copie para .env — NUNCA commite secrets reais
# Todos os valores de produção estão em ~/.claude/.secrets.env

# ── Database (PostgreSQL 16) ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:change-me@postgres:5432/investiq
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:change-me@postgres:5432/investiq

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
APP_URL=http://localhost:3100
CORS_ORIGINS=["http://localhost:3100"]

# ── JWT — RSA keypair ─────────────────────────────────────────────────────────
# Gerar: openssl genrsa -out private_key.pem 2048
#        openssl rsa -in private_key.pem -pubout -out public_key.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── Email ─────────────────────────────────────────────────────────────────────
# Provedor primário: Resend (resend.com — 3k/mês grátis, melhor DX)
# Se RESEND_API_KEY estiver vazio, cai automaticamente para Brevo
RESEND_API_KEY=

# Brevo (fallback — também usado pelo auth para emails de verificação/senha)
# Domínio investiq.com.br verificado no Brevo com DKIM + DMARC (2026-04-16)
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@investiq.com.br
BREVO_FROM_NAME=InvestIQ

# ── Market Data ───────────────────────────────────────────────────────────────
BRAPI_TOKEN=

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=["admin@investiq.com.br"]

# ── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENROUTER_API_KEY=
